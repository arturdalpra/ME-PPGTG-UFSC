# Commented out IPython magic to ensure Python compatibility.
import numpy as np
import pandas as pd
import statsmodels.api as sm
from functools import partial
from sklearn.model_selection import cross_validate, KFold, ShuffleSplit
from sklearn.base import clone

import matplotlib.pyplot as plt
# %matplotlib inline
#para exibir os gráficos dentro deste notebook

"""CARGA DOS DADOS:"""

# Carga do dataset
from google.colab import files #vou carregar o dataset diretamente do drive.
from google.colab import drive

# Carregar o dataset 09-baseTrindade.txt

# Montando o Google Drive
drive.mount('/content/drive')



# Caminho para o arquivo no Google Drive
file_path = '/content/drive/My Drive/TCC_SIN + ME_PPGTG/ME-PPGTG/09-baseTrindade.txt'

df = pd.read_csv(file_path, sep='\t', decimal=',')
df

# O dataset contém 71 elementos, e 11 variáveis, sendo 2 variáveis dependentes
# (escolher entre preco e vUnitario) e 10 variáveis independentes.

"""**Estudo da variável renda**
O código abaixo mostra que a variável é numérica e pode ser tratada por contínua porque há 19 valores distintos de renda em 71 elementos.

PREPARAÇÃO DOS DADOS:
"""

# Carga dos dados no dataframe
trindade_data = df

# Preparo das variáveis:
# Variável dependente
Y = trindade_data['vUnitario']

# Variáveis independentes que serão tratadas como dummy
vars_categoricas = ['nDorm', 'nVagas']

# Variáveis numéricas
vars_numericas = ['tipologia', 'renda', 'aPriva', 'idade']

# Criação das dummies apenas para nDorm e nVagas
X = pd.get_dummies(trindade_data[vars_categoricas + vars_numericas],
                   columns=vars_categoricas,
                   drop_first=True,
                   dtype=int)

# Adiciona constante (intercepto) para o modelo OLS
X = sm.add_constant(X)

# Conferência
print("Dimensões da matriz X:", X.shape)
print(f"Variáveis no modelo: {list(X.columns)}")
print("Número de dados:", len(Y))
print("\nPrimeiras CINCO linhas da matriz X, para conferência da carga dos dados:")
print(X.head())

X.head(21)

# verificação dos tipos
# para evitar problema NaN em dummies
print(X.dtypes)
print(Y.dtypes)

# ETAPA 1: AJUSTE DO MODELO MLR COMPLETO
print("\n" + "============================================================")
print("1. MODELO DE REGRESSÃO LINEAR MÚLTIPLA (MLR)")
print("============================================================")

# Nível de confiança de 80%
# (1 - alfa) = 0.80 portanto alfa = 0.20

# Ajustar o modelo completo
model_full = sm.OLS(Y, X) #usado statsmodels
results_full = model_full.fit()

#print(results_full.summary()) # default 97.5%


# Exibir o resumo do modelo com IC de 80%
# OBS: alpha 20% => nível de confiança 80%:
# produz limites entre 10% e 90% da distribuição (percentis 0.10 e 0.90).
print(results_full.summary(alpha=0.20))

print("\n\nNovamente, para ver mais casas:")
# Intervalos de confiança de 80%
ic_80 = results_full.conf_int(alpha=0.20)
ic_80.columns = ['IC_inferior_80%', 'IC_superior_80%']

# Construção do resumo
resumo = pd.DataFrame({
    'Variável': results_full.params.index,
    'Coeficiente': results_full.params.values,
    'P-valor': results_full.pvalues.values,
    'IC_inferior_80%': ic_80['IC_inferior_80%'].values,
    'IC_superior_80%': ic_80['IC_superior_80%'].values
})

# Abaixo o comando se quiser arredondar para 7 casas decimais
# (opcional, apenas para legibilidade)
#resumo = resumo.round(7)

print("\nResumo dos coeficientes (com IC de 80%):")
print(resumo)

# guardando os coeficientes num dataframe:

coefs_originais = results_full.params
#exibindo:
coefs_originais

# PREDIÇÃO DE UM ELEMENTO AVALIANDO QUALQUER
print("\nPREDIÇÃO DE UM AVALIANDO QUALQUER NESTE MODELO MLR")
print("="*50)

# Criar dados para predição (dataframe com uma única linha, usa iloc[0])
dados_pred = pd.DataFrame({
    'const': [1],
    'tipologia': [1],
    'renda': [trindade_data['renda'].mean()],
    'aPriva': [50],
    'idade': [4],
    'nDorm_3': [0],
    'nDorm_4': [1],
    'nVagas_2': [1]
})

# Garantir mesma ordem das colunas do modelo
dados_pred = dados_pred[X.columns]

# Fazer predição
predicao = results_full.predict(dados_pred)

print("Dados para predição:")
print(f"Tipologia: {dados_pred['tipologia'].iloc[0]}")
print(f"Renda: {dados_pred['renda'].iloc[0]:.2f}")
print(f"Área Privativa: {dados_pred['aPriva'].iloc[0]} m²")
print(f"Idade: {dados_pred['idade'].iloc[0]} anos")
print(f"Dormitórios: 4 (nDorm_4 = 1)")
print(f"Vagas: 2 (nVagas_2 = 1)")

print(f"\nValor Unitário Predito: R$ {predicao.iloc[0]:.2f}")

# ANÁLISE DA NORMALIDADE DOS RESÍDUOS
print("\n" + "="*60)
print("ANÁLISE DA NORMALIDADE DOS RESÍDUOS")
print("="*60)

# Calcular resíduos
residuos = results_full.resid
desvio_padrao_residuos = np.std(residuos)

print(f"Desvio padrão dos resíduos (s): {desvio_padrao_residuos:.4f}")

# Intervalos de referência
intervalos = [
    {'nome': '±1.00s', 'limite_inf': -1, 'limite_sup': 1, 'esperado': 0.6827},
    {'nome': '±1.64s', 'limite_inf': -1.64, 'limite_sup': 1.64, 'esperado': 0.9000},
    {'nome': '±1.96s', 'limite_inf': -1.96, 'limite_sup': 1.96, 'esperado': 0.9500}
]

print("\nCOMPARAÇÃO ENTRE DISTRIBUIÇÃO NORMAL E RESÍDUOS:")
print("-" * 70)
print(f"{'Intervalo':<12} {'% Esperado':<12} {'% Obtido':<12} {'Diferença':<12} {'Status':<10}")
print("-" * 70)

for intervalo in intervalos:
    # Calcular porcentagem de resíduos dentro do intervalo
    dentro_intervalo = np.sum(
        (residuos >= intervalo['limite_inf'] * desvio_padrao_residuos) &
        (residuos <= intervalo['limite_sup'] * desvio_padrao_residuos)
    ) / len(residuos)

    diferenca = dentro_intervalo - intervalo['esperado']

    # Avaliar se está próximo do esperado
    if abs(diferenca) <= 0.05:  # Tolerância de 5%
        status = "✓ PRÓXIMO"
    else:
        status = "✗ DISTANTE"

    print(f"{intervalo['nome']:<12} {intervalo['esperado']:<12.1%} {dentro_intervalo:<12.1%} {diferenca:<12.3f} {status:<10}")

# Estatísticas descritivas dos resíduos
print("\n" + "="*60)
print("ESTATÍSTICAS DESCRITIVAS DOS RESÍDUOS")
print("="*60)
print(f"Média dos resíduos: {np.mean(residuos):}")
print(f"Mediana dos resíduos: {np.median(residuos):}")
print(f"Assimetria (skewness): {residuos.skew():.4f}") #skewness = assimetria
print(f"Curtose (kurtosis): {residuos.kurtosis():.4f}") #kurtosis = curtose
print(f"Teste de Normalidade (Jarque-Bera):")
print(f"  Estatística: {sm.stats.stattools.jarque_bera(residuos)[0]:.4f}")
print(f"  p-valor: {sm.stats.stattools.jarque_bera(residuos)[1]:.4f}")

# Gráfico de comparação
import matplotlib.pyplot as plt
import scipy.stats as stats #biblioteca para álgebra linear e comp. científica

plt.figure(figsize=(12, 4))

# Subplot 1: Histograma com curva normal
plt.subplot(1, 2, 1)
plt.hist(residuos, bins=15, density=True, alpha=0.7, color='blue', label='Resíduos')
xmin, xmax = plt.xlim()
x = np.linspace(xmin, xmax, 100)
p = stats.norm.pdf(x, np.mean(residuos), np.std(residuos))
plt.plot(x, p, 'k', linewidth=2, label='Normal')
plt.title('Distribuição dos Resíduos vs Normal')
plt.xlabel('Resíduos')
plt.ylabel('Densidade')
plt.legend()

# Subplot 2: QQ-Plot
plt.subplot(1, 2, 2)
stats.probplot(residuos, dist="norm", plot=plt)
plt.title('Q-Q Plot dos Resíduos')

plt.tight_layout()
plt.show()

# Resumo da análise
print("\n" + "="*60)
print("RESUMO DA ANÁLISE DE NORMALIDADE")
print("="*60)

jb_pvalor = sm.stats.stattools.jarque_bera(residuos)[1]
if jb_pvalor > 0.05:
    print("✓ Teste Jarque-Bera: Resíduos seguem distribuição normal (p > 0.05)")
else:
    print("✗ Teste Jarque-Bera: Resíduos NÃO seguem distribuição normal (p ≤ 0.05)")

assimetria = residuos.skew()
if -0.5 <= assimetria <= 0.5:
    print("✓ Assimetria: Próxima de zero (distribuição simétrica)")
else:
    print(f"✗ Assimetria: Fora do intervalo [-0.5, 0.5] → {assimetria:.4f}")

curtose = residuos.kurtosis()
if -0.5 <= curtose <= 0.5:
    print("✓ Curtose: Próxima de zero (mesocúrtica)")
else:
    print(f"✗ Curtose: Fora do intervalo [-0.5, 0.5] → {curtose:.4f}")

# ANÁLISE DA VARIÂNCIA (ANOVA)
print("\n" + "="*60)
print("ANÁLISE DA VARIÂNCIA")
print("="*60)

# Calcular valores da ANOVA manualmente
n = len(Y)  # Número total de observações
k = len(results_full.params)-2  # Número de variáveis independentes
 #(excluindo colunas extras da modelagem dummy)

# Soma dos Quadrados
SQR = results_full.ess  # Soma dos Quadrados da Regressão (Explicada)
SQE = results_full.ssr  # Soma dos Quadrados dos Resíduos (Não Explicada)
SQT = SQR + SQE        # Soma dos Quadrados Total

# Graus de Liberdade
gl_reg = k              # Graus de liberdade da regressão
gl_res = n - k - 1      # Graus de liberdade dos resíduos
gl_total = n - 1        # Graus de liberdade total

# Quadrados Médios
QM_reg = SQR / gl_reg   # Quadrado Médio da Regressão
QM_res = SQE / gl_res   # Quadrado Médio dos Resíduos

# Estatística F
F = QM_reg / QM_res

# Criar tabela ANOVA formatada
print(f"{'Fonte de variação':<20} {'Soma dos Quadrados':<20} {'Graus de Liberdade':<18} {'Quadrado Médio':<18} {'F':<10}")
print("-" * 90)
print(f"{'Explicada':<20} {SQR:<20.2f} {gl_reg:<18} {QM_reg:<18.2f} {F:<10.3f}")
print(f"{'Não Explicada':<20} {SQE:<20.3f} {gl_res:<18} {QM_res:<18.3f}")
print(f"{'Total':<20} {SQT:<20.2f} {gl_total:<18}")

# Estatísticas adicionais
print("\n" + "="*60)
print("ESTATÍSTICAS ADICIONAIS")
print("="*60)
print(f"R²: {results_full.rsquared:.4f}")
print(f"R² Ajustado: {results_full.rsquared_adj:.4f}")
print(f"Estatística F: {F:.3f}")
print(f"p-valor (F): {results_full.f_pvalue:}")
print(f"Número de observações (n): {n}")
print(f"Número de variáveis independentes (k): {k}")

# Interpretação do teste F
print("\n" + "="*60)
print("INTERPRETAÇÃO DO TESTE F")
print("="*60)
if results_full.f_pvalue < 0.05:
    print("✓ O modelo é estatisticamente significativo (p < 0.05)")
    print("  → Rejeita-se H₀: todos os coeficientes são zero")
    print("  → Pelo menos uma variável independente explica a variação em Y")
else:
    print("✗ O modelo NÃO é estatisticamente significativo (p ≥ 0.05)")
    print("  → Não se rejeita H₀: todos os coeficientes podem ser zero")
    print("  → As variáveis independentes não explicam significativamente a variação em Y")

# Proporção da variância explicada
print(f"\nProporção da variância explicada: {results_full.rsquared:.1%}")
print(f"Proporção da variância não explicada: {(1 - results_full.rsquared):.1%}")

# Verificação - comparar com valores do summary
print("\n" + "="*60)
print("VERIFICAÇÃO - VALORES DO SUMMARY")
print("="*60)
print(f"F-statistic do summary: {results_full.fvalue:}")
print(f"Prob (F-statistic) do summary: {results_full.f_pvalue:}")
print(f"R-squared do summary: {results_full.rsquared:.4f}")

#correlação:

# Selecionar variáveis para correlação
vars_correlacao = ['vUnitario', 'tipologia', 'renda', 'aPriva', 'idade', 'nDorm', 'nVagas']
correlacao = trindade_data[vars_correlacao].corr()
print(correlacao)

# Correlação com formatação
correlacao = trindade_data[vars_correlacao].corr().round(3)
print("MATRIZ DE CORRELAÇÃO:")
print(correlacao)

import matplotlib.pyplot as plt
import seaborn as sns



# Correlação de Pearson (padrão)
correlacao_pearson = trindade_data[vars_correlacao].corr(method='pearson')
print("Correlação de Pearson")
print(correlacao_pearson)
plt.figure(figsize=(10, 8))
sns.heatmap(correlacao_pearson, annot=True, cmap='coolwarm', center=0, fmt='.2f')
plt.title('Matriz de Correlação de Pearson')
plt.show()

print("\n")

# Correlação de Spearman
correlacao_spearman = trindade_data[vars_correlacao].corr(method='spearman')
print("Correlação de Spearman")
print(correlacao_spearman)
plt.figure(figsize=(10, 8))
sns.heatmap(correlacao_spearman, annot=True, cmap='coolwarm', center=0, fmt='.2f')
plt.title('Matriz de Correlação de Spearman')
plt.show()

# DISTÂNCIA DE COOK
print("\n" + "="*60)
print("ANÁLISE DE INFLUÊNCIA - DISTÂNCIA DE COOK")
print("="*60)

# Calcular a Distância de Cook
influence = results_full.get_influence()
cooks_d = influence.cooks_distance
k = len(results_full.params)-2
print(f"k = {k}")

# Extrair os valores da Distância de Cook
cooks_distance = cooks_d[0]  # Valores da distância
p_values = cooks_d[1]        # Valores p (opcional)

# Criar DataFrame com os resultados
cooks_df = pd.DataFrame({
    'Observação': range(1, len(cooks_distance) + 1),
    'Distância_Cook': cooks_distance
})

# Ordenar pelas observações mais influentes
cooks_df_sorted = cooks_df.sort_values('Distância_Cook', ascending=False)

print("TOP 10 OBSERVAÇÕES MAIS INFLUENTES:")
print("-" * 50)
print(cooks_df_sorted.head(10).to_string(index=False))

# Estatísticas descritivas
print("\nESTATÍSTICAS DA DISTÂNCIA DE COOK:")
print("-" * 40)
print(f"Média: {cooks_distance.mean():.6f}")
print(f"Desvio Padrão: {cooks_distance.std():.6f}")
print(f"Máximo: {cooks_distance.max():.6f}")
print(f"Mínimo: {cooks_distance.min():.6f}")
print(f"Mediana: {np.median(cooks_distance):.6f}")

# Identificar observações influentes (limite comum: > 4/ (n-k-1))
limite_cook = 4 / (len(Y)-k-1)
observacoes_influentes = cooks_df[cooks_df['Distância_Cook'] > limite_cook]

print(f"\nOBSERVAÇÕES INFLUENTES (Distância de Cook > {limite_cook:.4f}):")
print("-" * 60)
if len(observacoes_influentes) > 0:
    print(observacoes_influentes.to_string(index=False))
else:
    print("Nenhuma observação considerada influente")

# Gráfico da Distância de Cook
import matplotlib.pyplot as plt

plt.figure(figsize=(12, 6))

plt.subplot(1, 2, 1)
plt.stem(cooks_distance, basefmt=" ")
plt.axhline(y=limite_cook, color='r', linestyle='--', label=f'Limite = {limite_cook:.4f}')
plt.title('Distância de Cook por Observação')
plt.xlabel('Observação')
plt.ylabel('Distância de Cook')
plt.legend()
plt.grid(True, alpha=0.3)

plt.show()

# Interpretação
print("\n" + "="*60)
print("INTERPRETAÇÃO DA DISTÂNCIA DE COOK")
print("="*60)
print("A Distância de Cook mede a influência de cada observação no modelo.")
print(f"Limite de referência: 4/(n-k-1) = 4/({len(Y)}-k-1) = {limite_cook:.4f}")
print("\nObservações com Distância de Cook > limite podem ser influentes:")
print("- Valores altos indicam que a observação tem grande influência")
print("- Pode ser necessário investigar se são outliers ou dados problemáticos")

if len(observacoes_influentes) > 0:
    print(f"\n→ {len(observacoes_influentes)} observação(ões) potencialmente influente(s)")
    print("  Considere verificar a qualidade desses dados")
else:
    print(f"\n→ Nenhuma observação considerada influente")
    print("  O modelo não é sensível a observações individuais")

from scipy import stats  # Para o Q-Q plot

import matplotlib.pyplot as plt
import numpy as np
from scipy import stats

# GRÁFICO DE ADERÊNCIA E RESÍDUOS
print("\n" + "="*60)
print("GRÁFICO DE ADERÊNCIA E RESÍDUOS DA REGRESSÃO")
print("="*60)

# Calcular valores preditos e resíduos
y_pred = results_full.predict(X)
residuos = results_full.resid

# Calcular resíduos padronizados
residuos_padronizados = residuos / np.std(residuos)

# Criar figura com subplots
fig, (ax1, ax2) = plt.subplots(1, 2, figsize=(15, 6))

# GRÁFICO 1: ADERÊNCIA (Observado vs Estimado)
ax1.scatter(y_pred, Y, alpha=0.6, color='blue', label='Observações')
# Linha de Aderência Perfeita (bissetriz)
ax1.plot([Y.min(), Y.max()], [Y.min(), Y.max()], 'r--', lw=2, label='Linha de Aderência Perfeita')

# Calcular R² para o gráfico
r2 = results_full.rsquared
ax1.text(0.05, 0.95, f'R² = {r2:.4f}', transform=ax1.transAxes,
         fontsize=12, verticalalignment='top', bbox=dict(boxstyle='round', facecolor='white', alpha=0.8))

ax1.set_xlabel('Valores Preditos (Estimados)')
ax1.set_ylabel('Valores Observados (Reais)')
ax1.set_title('GRÁFICO DE ADERÊNCIA\nObservado vs Estimado')
ax1.legend()
ax1.grid(True, alpha=0.3)

# GRÁFICO 2: RESÍDUOS PADRONIZADOS vs VALORES PREDITOS
ax2.scatter(y_pred, residuos_padronizados, alpha=0.6, color='green', label='Resíduos Padronizados')
ax2.axhline(y=0, color='red', linestyle='--', linewidth=2, label='Linha Zero')

# Adicionar bandas de desvios padronizados
ax2.axhline(y=2, color='orange', linestyle=':', alpha=0.7, label='±2 DP')
ax2.axhline(y=-2, color='orange', linestyle=':', alpha=0.7)
ax2.axhline(y=3, color='red', linestyle=':', alpha=0.5, label='±3 DP')
ax2.axhline(y=-3, color='red', linestyle=':', alpha=0.5)

ax2.set_xlabel('Valores Preditos (Estimados)')
ax2.set_ylabel('Resíduos Padronizados')
ax2.set_title('GRÁFICO DE RESÍDUOS PADRONIZADOS\nResíduos vs Valores Preditos')
ax2.legend()
ax2.grid(True, alpha=0.3)

plt.tight_layout()
plt.show()

# Estatísticas para interpretação
print("\nESTATÍSTICAS DOS RESÍDUOS PADRONIZADOS:")
print("-" * 45)
print(f"R² do modelo: {r2:.4f}")
print(f"Média dos resíduos padronizados: {np.mean(residuos_padronizados):}")
print(f"Desvio padrão dos resíduos padronizados: {np.std(residuos_padronizados):.4f}")

# Contagem de resíduos por faixa de desvios
print(f"\nDISTRIBUIÇÃO DOS RESÍDUOS PADRONIZADOS:")
print("-" * 45)
faixas = [
    ('Dentro de ±1 DP', np.sum(np.abs(residuos_padronizados) <= 1)),
    ('Dentro de ±2 DP', np.sum(np.abs(residuos_padronizados) <= 2)),
    ('Dentro de ±3 DP', np.sum(np.abs(residuos_padronizados) <= 3)),
    ('Fora de ±3 DP', np.sum(np.abs(residuos_padronizados) > 3))
]

for faixa, count in faixas:
    percentual = (count / len(residuos_padronizados)) * 100
    print(f"{faixa}: {count}/{len(residuos_padronizados)} observações ({percentual:.1f}%)")

# Identificar outliers (resíduos > |3| DP)
outliers = np.where(np.abs(residuos_padronizados) > 3)[0]
if len(outliers) > 0:
    print(f"\nOBSERVAÇÕES COM RESÍDUOS > |3| DP (Possíveis Outliers):")
    print("-" * 55)
    for idx in outliers:
        print(f"Obs {idx+1}: Resíduo padronizado = {residuos_padronizados[idx]:.3f}")

# Interpretação
print("\n" + "="*60)
print("INTERPRETAÇÃO DOS GRÁFICOS")
print("="*60)
print("GRÁFICO DE ADERÊNCIA (Esquerda):")
print("✓ Pontos próximos à 'Linha de Aderência Perfeita' = boa aderência")
print("✓ Dispersão sistemática = possíveis problemas no modelo")

print("\nGRÁFICO DE RESÍDUOS PADRONIZADOS (Direita):")
print("✓ Resíduos entre ±2 DP = comportamento esperado (95% dos dados)")
print("✓ Resíduos entre ±3 DP = valores atípicos moderados")
print("✓ Resíduos fora de ±3 DP = possíveis outliers influentes")

# Gráfico adicional: Distribuição dos resíduos padronizados
plt.figure(figsize=(12, 4))

plt.subplot(1, 2, 1)
plt.hist(residuos_padronizados, bins=15, alpha=0.7, color='skyblue', edgecolor='black', density=True)
# Adicionar curva normal padrão para comparação
x = np.linspace(-4, 4, 100)
plt.plot(x, stats.norm.pdf(x, 0, 1), 'r-', label='N(0,1)')
plt.axvline(x=0, color='red', linestyle='--', linewidth=1)
plt.axvline(x=2, color='orange', linestyle=':', alpha=0.7)
plt.axvline(x=-2, color='orange', linestyle=':', alpha=0.7)
plt.axvline(x=3, color='red', linestyle=':', alpha=0.5)
plt.axvline(x=-3, color='red', linestyle=':', alpha=0.5)
plt.title('Distribuição dos Resíduos Padronizados')
plt.xlabel('Resíduos Padronizados')
plt.ylabel('Densidade')
plt.legend()
plt.grid(True, alpha=0.3)

plt.subplot(1, 2, 2)
stats.probplot(residuos_padronizados, dist="norm", plot=plt)
plt.title('Q-Q Plot dos Resíduos Padronizados')

plt.tight_layout()
plt.show()

import matplotlib.pyplot as plt
import numpy as np
import pandas as pd
import seaborn as sns

print("\n" + "="*60)
print("ANÁLISE INDIVIDUAL POR VARIÁVEL: TENDÊNCIA DE CRESCIMENTO")
print("="*60)

# Coeficientes do modelo
coeficientes = results_full.params
constante = coeficientes['const'] if 'const' in coeficientes.index else 0

# Criar gráficos individuais para cada variável independente
for var in coeficientes.index:
    if var != 'const':
        print(f"\n--- ANALISANDO VARIÁVEL: {var} ---")

        # Dados da variável
        if var in X.columns:
            x_values = X[var]
            coef = coeficientes[var]

            # Criar figura individual
            plt.figure(figsize=(10, 6))

            # Definir range completo da variável X
            x_min = x_values.min()
            x_max = x_values.max()
            x_range = np.linspace(x_min, x_max, 100)

            # Calcular valores estimados (reta Y_hat)
            y_estimated = constante + coef * x_range

            # Plotar a reta de tendência
            plt.plot(x_range, y_estimated,
                    linewidth=3,
                    color='green' if coef > 0 else 'red',
                    alpha=0.8,
                    label=f'Reta de Tendência (Coef: {coef:.4f})')

            # Adicionar pontos dos dados reais para contexto
            plt.scatter(x_values, Y,
                       alpha=0.5,
                       color='blue',
                       s=30,
                       label='Dados Observados')

            # Configurações do gráfico
            plt.xlabel(f'Valores de {var}', fontsize=12, fontweight='bold')
            plt.ylabel('Valor Estimado (Y_hat)', fontsize=12, fontweight='bold')

            # Título informativo
            direcao = "CRESCENTE ↗" if coef > 0 else "DECRESCENTE ↘"
            cor_titulo = 'green' if coef > 0 else 'red'
            plt.title(f'RELAÇÃO: {var} → VALOR ESTIMADO\n' +
                     f'Coeficiente: {coef:.4f} | Tendência: {direcao}',
                     fontsize=14, fontweight='bold', color=cor_titulo)

            # Grade
            plt.grid(True, alpha=0.3)

            # Legenda
            plt.legend()

            # Adicionar estatísticas descritivas
            stats_text = (f'Estatísticas de {var}:\n'
                         f'Mín: {x_min:.2f}\n'
                         f'Máx: {x_max:.2f}\n'
                         f'Média: {x_values.mean():.2f}\n'
                         f'Coef: {coef:.4f}')

            plt.annotate(stats_text,
                        xy=(0.02, 0.98),
                        xycoords='axes fraction',
                        bbox=dict(boxstyle="round,pad=0.3", fc="white", alpha=0.8),
                        verticalalignment='top',
                        fontsize=10)

            plt.tight_layout()
            plt.show()

            # Print informativo
            print(f"Coeficiente: {coef:.4f}")
            print(f"Faixa de {var}: {x_min:.2f} a {x_max:.2f}")
            print(f"Tendência: {direcao}")
            print(f"Interpretação: Um aumento unitário em {var} está associado a {'aumento' if coef > 0 else 'redução'} de {abs(coef):.4f} em Y")

# GRÁFICO COMPARATIVO FINAL
