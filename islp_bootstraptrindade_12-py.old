import numpy as np

def calcular_pvalues_bicaudais(resultados_boot, coefs_originais):
    """
    Calcula APENAS p-valores bicaudais a partir do bootstrap.
    Para as variáveis: p_bi = min(2 * p_uni, 1.0)
    Para o intercepto: p_bi = 2 * min(P<=0, P>=0)

    Retorna:
      - dict {coluna: p_bicaudal}
    """

    pvalues_bicaudal = {}

    # Intercepto
    nome_intercepto = resultados_boot.columns[0]
    vals = resultados_boot[nome_intercepto]

    p_inter = 2 * min((vals <= 0).mean(), (vals >= 0).mean())
    p_inter = min(max(p_inter, 0.0), 1.0)

    pvalues_bicaudal[nome_intercepto] = p_inter

    # Variáveis restantes
    for col in resultados_boot.columns[1:]:

        sinal = np.sign(coefs_originais[col])

        if sinal > 0:
            p_uni = (resultados_boot[col] <= 0).mean()
        elif sinal < 0:
            p_uni = (resultados_boot[col] >= 0).mean()
        else:
            p_uni = 1.0

        p_bi = min(2.0 * p_uni, 1.0)

        pvalues_bicaudal[col] = p_bi

    return pvalues_bicaudal


        #if sinal > 0:
            # coef esperado positivo: teste unilateral à direita
            # H0: beta menor ou igual a zero
            # a intenção do teste é identificar qual fração das reamostragens
            # produziu um coeficiente NEGATIVO ou zerado
            #


        #elif sinal < 0:
            # coef esperado negativo: teste unilateral à esquerda
            # H0: beta maior ou igual a zero
            # a intenção do teste é identificar qual fração das reamostragens
            # produziu um coeficiente POSITIVO ou zerado
            #

# chamada da função e exibição:

p_bi = calcular_pvalues_bicaudais(resultados_boot, coefs_originais)

print("p-valores bootstrap bicaudais:")
for col, p in p_bi.items():
    print(col, ":", p)

