import matplotlib.pyplot as plt
import math

def plot_bootstrap_com_IC(resultados_boot, coefs_originais,
                   IC_percentil, IC_normal, IC_bca):

    p = resultados_boot.shape[1]
    nrows = math.ceil(p / 3)

    fig, axes = plt.subplots(nrows=nrows, ncols=3, figsize=(15, 4*nrows))
    axes = axes.flatten()

    for i, col in enumerate(resultados_boot.columns):
        ax = axes[i]

        # Distribuição bootstrap
        resultados_boot[col].plot(kind='kde', ax=ax)

        # Valor original
        theta_hat = coefs_originais[col]
        ax.axvline(theta_hat, color='red', linestyle='--', lw=1,
                   label=f"Original")

        # Intervalo Percentil (apenas uma linha com label)
        plow, phigh = IC_percentil.loc[col]
        ax.axvline(plow, color='blue', linestyle=':', lw=1, alpha=0.7)
        ax.axvline(phigh, color='blue', linestyle=':', lw=1, alpha=0.7, label='IC Percentil')

        # Intervalo Normal (apenas uma linha com label)
        nlow, nhigh = IC_normal.loc[col]
        ax.axvline(nlow, color='green', linestyle=':', lw=1, alpha=0.7)
        ax.axvline(phigh, color='green', linestyle=':', lw=1, alpha=0.7, label='IC Normal')

        # Intervalo BCa (apenas uma linha com label)
        blow, bhigh = IC_bca.loc[col]
        ax.axvline(blow, color='brown', linestyle='-.', lw=1, alpha=0.7)
        ax.axvline(bhigh, color='brown', linestyle='-.', lw=1, alpha=0.7, label='IC BCa')

        ax.set_title(f"{col}")
        ax.set_xlabel("Valor do coeficiente")
        ax.legend()

    # Remover subplots vazios
    for j in range(i+1, len(axes)):
        fig.delaxes(axes[j])

    plt.tight_layout()
    plt.show()

