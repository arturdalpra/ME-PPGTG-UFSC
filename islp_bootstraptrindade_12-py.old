#mse = np.mean((y_test - y_pred)**2)

# Continuação do holdout 70% x 30%

# ============================================================
# AVALIAÇÃO DO DESEMPENHO NO CONJUNTO DE TESTE
# ============================================================

# MSE
mse = mean_squared_error(y_test, y_pred)
#test_mse = np.mean((y_test - y_pred)**2)

# RMSE
rmse = np.sqrt(mean_squared_error(y_test, y_pred))

# MAE
mae = mean_absolute_error(y_test, y_pred)

# MAPE
mape = mean_absolute_percentage_error(y_test, y_pred)

# R² no teste
ss_res = np.sum((y_test - y_pred)**2)
ss_tot = np.sum((y_test - np.mean(y_test))**2)
r2_test = 1 - (ss_res / ss_tot)

# R² ajustado no teste
n = X_test.shape[0]      # número de observações no teste
p = X_test.shape[1] - 1  # preditores (descontando o intercepto)
r2_adj_test = 1 - (1 - r2_test) * (n - 1) / (n - p - 1)

