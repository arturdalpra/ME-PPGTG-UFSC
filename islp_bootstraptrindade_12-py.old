import matplotlib.pyplot as plt
import numpy as np
from scipy.stats import gaussian_kde

def plot_bootstrap_existing(resultados_boot, resumo_boot=resumo_boot, betas_originais=coefs_originais):
    """
    Gera gráficos dos coeficientes bootstrap já calculados.
    Pode usar ou resumo_boot ou betas_originais para marcar o beta original.
    """

    coef_names = resultados_boot.columns
    num = len(coef_names)
    ncols = 3
    nrows = int(np.ceil(num / ncols))

    plt.figure(figsize=(18, 5 * nrows))

    for i, col in enumerate(coef_names):
        ax = plt.subplot(nrows, ncols, i + 1)
        vals = resultados_boot[col].dropna()

        # Histograma
        ax.hist(vals, bins=30, density=True, alpha=0.4, label="Bootstrap")

        # KDE
        try:
            kde = gaussian_kde(vals)
            xs = np.linspace(vals.min(), vals.max(), 300)
            ax.plot(xs, kde(xs), label="KDE")
        except:
            pass  # KDE falha se não houver variância

        # Linha do coeficiente original
        if betas_originais is not None:
            ax.axvline(betas_originais[col], color='red', linestyle='--', linewidth=2,
                       label="Coef. original")

        # ICs do seu resumo_boot (se existir)
        if resumo_boot is not None:
            if f'IC 10% (inferior)' in resumo_boot.columns:
                li = resumo_boot.loc[col, 'IC 10% (inferior)']
                ls = resumo_boot.loc[col, 'IC 90% (superior)']
                ax.axvline(li, color='green', linestyle='--', label='IC inferior')
                ax.axvline(ls, color='green', linestyle='--', label='IC superior')

        ax.set_title(f'Distribuição Bootstrap – {col}')
        ax.legend()

    plt.tight_layout()
    plt.show()

plot_bootstrap_existing(
    resultados_boot,
    resumo_boot=resumo_boot,
    betas_originais=coefs_originais
)

import matplotlib.pyplot as plt
import numpy as np

def plot_bootstrap_ICs(
    resultados_boot,
    betas_originais,
    IC_percentil,
    IC_student,
    IC_bca
):

    coef_nomes = resultados_boot.columns
    n = len(coef_nomes)
    ncols = 3
    nrows = int(np.ceil(n / ncols))

    fig, axes = plt.subplots(nrows=nrows, ncols=ncols,
                             figsize=(18, 4 * nrows))
    axes = axes.flatten()

    for i, col in enumerate(coef_nomes):
        ax = axes[i]

        # KDE
        resultados_boot[col].plot(kind='kde', ax=ax, lw=2)

        # Linha vertical do coeficiente original
        ax.axvline(betas_originais[col], color='red',
                   linestyle='--', lw=2, label='Original')

        # Percentil
        ax.axvline(IC_percentil.loc[col, '10%'], color='blue',
                   linestyle=':', lw=1.8)
        ax.axvline(IC_percentil.loc[col, '90%'], color='blue',
                   linestyle=':', lw=1.8, label='Percentil 80%')

        # Studentizado
        ax.axvline(IC_student.loc[col, '10%'], color='green',
                   linestyle=':', lw=1.8)
        ax.axvline(IC_student.loc[col, '90%'], color='green',
                   linestyle=':', lw=1.8, label='Studentizado 80%')

        # BCa
        ax.axvline(IC_bca.loc[col, '10%'], color='purple',
                   linestyle=':', lw=2)
        ax.axvline(IC_bca.loc[col, '90%'], color='purple',
                   linestyle=':', lw=2, label='BCa 80%')

        ax.set_title(f"Distribuição Bootstrap — {col}")
        ax.set_xlabel("Valor do coeficiente")
        ax.set_ylabel("Densidade")

        ax.legend()

    # remover gráficos vazios
    for j in range(i + 1, len(axes)):
        fig.delaxes(axes[j])

    plt.tight_layout()
    plt.show()



