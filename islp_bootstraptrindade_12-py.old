# Carga dos dados no dataframe
trindade_data = df

# Preparo das variáveis:
# Variável dependente
Y = trindade_data['vUnitario']

# Variáveis independentes que serão tratadas como dummy
vars_categoricas = ['nDorm', 'nVagas']

# Variáveis numéricas
vars_numericas = ['tipologia', 'renda', 'aPriva', 'idade']

# Criação das dummies apenas para nDorm e nVagas
X = pd.get_dummies(trindade_data[vars_categoricas + vars_numericas],
                   columns=vars_categoricas,
                   drop_first=True,
                   dtype=int)

# Adiciona constante (intercepto) para o modelo OLS
X = sm.add_constant(X)

# Conferência
print("Dimensões da matriz X:", X.shape)
print(f"Variáveis no modelo: {list(X.columns)}")
print("Número de dados:", len(Y))
print("\nPrimeiras CINCO linhas da matriz X, para conferência da carga dos dados:")
print(X.head())

"""#ABORDAGEM EM AMBIENTE DE POUCOS DADOS: início
(ajustando o modelo MLR para POUCOS dados)
"""

# AJUSTE DO MODELO MLR COMPLETO
# objetivo: obter os coeficientes beta
print("\n" + "============================================================")
print("1. MODELO DE REGRESSÃO LINEAR MÚLTIPLA (MLR)")
print("============================================================")

# Nível de confiança de 80%
# (1 - alfa) = 0.80 portanto alfa = 0.20

# Ajustar o modelo completo
model_full = sm.OLS(Y, X)
results_full = model_full.fit()
# print(results_full.summary()) # default 97.5%

# Exibir o resumo do modelo com IC de 80%
print(results_full.summary(alpha=0.20))

# Intervalos de confiança de 80%
ic_80 = results_full.conf_int(alpha=0.20)
ic_80.columns = ['IC_inferior_80%', 'IC_superior_80%']

# Construção do resumo
resumo = pd.DataFrame({
    'Variável': results_full.params.index,
    'Coeficiente': results_full.params.values,
    'P-valor': results_full.pvalues.values,
    'IC_inferior_80%': ic_80['IC_inferior_80%'].values,
    'IC_superior_80%': ic_80['IC_superior_80%'].values
})

# Arredondar para 4 casas decimais (opcional, apenas para legibilidade)
resumo = resumo.round(4)

print("\nResumo dos coeficientes (com IC de 80%):")
print(resumo)

"""#ABORDAGEM EM AMBIENTE DE POUCOS DADOS:
(ajustado o modelo MLR para 71 dados)
(procede-se a obtenção dos valores que são relevantes p\ as análises seguintes:)
(a intenção é apenas pegar os coeficientes, a ideia é coletar corretamente)
"""

print("\n" + "="*80)
print("IDENTIFICAÇÃO DOS RESULTADOS DO MODELO MLR - CONFORME NBR 14.653-2")
print("="*80)

# Limites conforme NBR 14.653-2
LIMITE_PVALOR_COEFICIENTES = 0.30  # 30% => item 5 da Tabela 1 do enquadramento MLR
LIMITE_PVALOR_F_STATISTIC = 0.05   # 5% => item 6 da Tabela 1 do enquadramento MLR


# a) Valor-p de cada variável (limite de 30% para GF I, conforme NBR 14.653-2)
print("\na) VALOR-P DE CADA VARIÁVEL (Limite: 30% - NBR 14.653-2):")
print("-" * 60)
for var, p_val in zip(results_full.params.index, results_full.pvalues):
    # CORREÇÃO: Usar os p-valores exatos do summary
    significancia = "*** SIGNIFICATIVO ***" if p_val <= LIMITE_PVALOR_COEFICIENTES else "Não significativo"
    print(f"{var:<20}: valor-p = {p_val:} {significancia}")

# b) Resultado do teste de significância
print("\nb) TESTE DE SIGNIFICÂNCIA DOS COEFICIENTES (valor-p máximo de 30% - Tabela 1 (item 5) da NBR 14.653-2):")
print("-" * 60)
print("H₀: Coeficiente = 0")
print("H₁: Coeficiente \u2260 0")
print(f"\nDecisão: Rejeitar H₀ se p-valor \u2264 {LIMITE_PVALOR_COEFICIENTES}")
print("-" * 60)

variaveis_significativas = []
variaveis_nao_significativas = []

for var, p_val in zip(results_full.params.index, results_full.pvalues):
    if var == 'const':
        continue  # Geralmente não testamos significância do intercepto
    if p_val <= LIMITE_PVALOR_COEFICIENTES:
        variaveis_significativas.append((var, p_val))
    else:
        variaveis_nao_significativas.append((var, p_val))

print(f"\nVariáveis SIGNIFICATIVAS (p-valor \u2264 {LIMITE_PVALOR_COEFICIENTES}):")
if variaveis_significativas:
    for var, p_val in variaveis_significativas:
        print(f"  \u2713 {var:<20}: p-valor = {p_val:}")
else:
    print("  Nenhuma variável significativa")

print(f"\nVariáveis NÃO SIGNIFICATIVAS (p-valor > {LIMITE_PVALOR_COEFICIENTES}):")
if variaveis_nao_significativas:
    for var, p_val in variaveis_nao_significativas:
        print(f"  \u2718 {var:<20}: valor-p = {p_val:}")
else:
    print("  Todas as variáveis são significativas")

# c) Valor do coeficiente de cada variável
print("\nc) VALOR DOS COEFICIENTES E INTERPRETAÇÃO:")
print("-" * 70)
for var, coef, ic_inf, ic_sup, p_val in zip(resumo['Variável'],
                                           resumo['Coeficiente'],
                                           resumo['IC_inferior_80%'],
                                           resumo['IC_superior_80%'],
                                           resumo['P-valor']): # FIX: Changed 'valor-p' to 'P-valor'

    if var == 'const':
        print(f"{var:<20}: Coef = {coef:}")
        print(f"                      \u2192 Intercepto: valor base quando todas variáveis são zero")
    else:
        # Determinar significância baseada no p-valor (limite 30%)
        if p_val <= LIMITE_PVALOR_COEFICIENTES:
            if coef > 0:
                efeito = "Efeito POSITIVO significativo (valor-p \u2264 0.30)"
            else:
                efeito = "Efeito NEGATIVO significativo (valor-p \u2264 0.30)"
        else:
            efeito = "Efeito NÃO SIGNIFICATIVO (valor-p > 0.30)"

        print(f"{var:<20}: Coef = {coef:} (valor-p = {p_val:})")
        print(f"                      IC 80%: [{ic_inf:}, {ic_sup:}]")
        print(f"                      \u2192 {efeito}")

# Resumo estatístico geral CONFORME NBR 14.653-2
print("\n" + "="*80)
print("RESUMO ESTATÍSTICO GERAL DO MODELO - CONFORME NBR 14.653-2")
print("="*80)
print(f"R\u00b2: {results_full.rsquared:}")
print(f"R\u00b2 Ajustado: {results_full.rsquared_adj:}")
print(f"F-statistic: {results_full.fvalue:}")
print(f"Prob (F-statistic): {results_full.f_pvalue:}")

# Teste de significância global do modelo (limite 5% conforme NBR 14.653-2)
print(f"\nTESTE DE SIGNIFIC\u00c2NCIA GLOBAL DO MODELO (Limite: 5% - NBR 14.653-2):")
print("-" * 60)
if results_full.f_pvalue <= LIMITE_PVALOR_F_STATISTIC:
    print("\u2713 MODELO SIGNIFICATIVO: Rejeitar H₀ (p \u2264 0.05)")
    print("  \u2192 O modelo como um todo é estatisticamente significativo")
else:
    print("\u2718 MODELO N\u00c3O SIGNIFICATIVO: N\u00e3o rejeitar H₀ (p > 0.05)")
    print("  \u2192 O modelo como um todo não é estatisticamente significativo")

print(f"\nNúmero de observações: {results_full.nobs}")
print(f"Número de variáveis: {len(results_full.params)}")

# Contagem de variáveis significativas (limite 30%)
n_significativas = len(variaveis_significativas)
n_total_variaveis = len(results_full.params) - 1  # Excluindo constante
print(f"\nVariáveis significativas (valor-p <= 30% - NBR 14.653-2): {n_significativas}/{n_total_variaveis} "
      f"({n_significativas/n_total_variaveis*100:}%)")

# Exportar resultados para DataFrame com classificação NBR 14.653-2
resultados_nbr = pd.DataFrame({
    'Variável': results_full.params.index,
    'Coeficiente': results_full.params.values,
    'Erro_Padrão': results_full.bse.values,
    'Estatística_t': results_full.tvalues.values,
    'valor_p': results_full.pvalues.values,
    'Significativo_NBR': [p_val <= LIMITE_PVALOR_COEFICIENTES if var != 'const' else 'Intercepto'
                         for var, p_val in zip(results_full.params.index, results_full.pvalues)], # FIX: Changed results.pvalues to results_full.pvalues
    'IC_Inferior_80%': ic_80['IC_inferior_80%'].values,
    'IC_Superior_80%': ic_80['IC_superior_80%'].values
}).round(4)

print(f"\nDataFrame com resultados conforme NBR 14.653-2:")
print(resultados_nbr)

# Verificação final
print(f"\n" + "="*80)
print("VERIFICAÇÃO FINAL - CONFORMIDADE NBR 14.653-2")
print("="*80)
print(f"\u2713 Limite p-valor coeficientes: {LIMITE_PVALOR_COEFICIENTES} (30%)")
print(f"\u2713 Limite p-valor F-statistic: {LIMITE_PVALOR_F_STATISTIC} (5%)")
print(f"\u2713 Modelo global significativo: {results_full.f_pvalue <= LIMITE_PVALOR_F_STATISTIC}")
print(f"\u2713 Variáveis individuais significativas: {n_significativas} de {n_total_variaveis}")

"""A partir do dataset (dado pelas variáveis X e Y), procede-se a reamostragem SEM reposição contendo 21 elementos.

Isso significa que não devem haver elementos repetidos.

Na formação de cada conjunto reamostrado, há uma correspondência entre X e Y, o comando sample já considera isso.

Fiz B = 1000 reamostragens.

A seguir, para cada reamostra, dentro do loop, foi ajustado um modelo MLR, e este modelo foi considerado válido se atendido o seguinte:


a) compatibilidade de sinais: cada variável deve ter coeficiente de mesmo sinal do coeficiente da MLR com o dataset original


b) o maior valor-p das variáveis independentes deve ser <=30%


c) significância do modelo (dado pelo teste F) deve ser <=5%


O objetivo é saber qual a quantidade de modelos válidos nesta reamostragem SEM reposição que gera subconjuntos de tamanho 21 (é a quantidade mínima para enquadrar em GF I).



Para não haver reamostragem de conjuntos iguais, foi usado hash

Para a micronumerosidade, verifica-se a se contagem >= 3 observações por categoria. Somente são aceitos conjuntos de dados onde o número de dados de mesma característica para as variáveis dicotômicas seja >= 3

Verificação do IC 80% sem zero: para garantir que IC não contenha zero para variáveis significativas

Todos p-valores ≤ 30%: verifica cada variável, poderia ter feito para verificar o valor máximo.
"""

import pandas as pd
import numpy as np
import statsmodels.api as sm

print("\n" + "="*80)
print("REAMOSTRAGEM SEM REPOSIÇÃO - MODELOS VÁLIDOS REVISADO")
print("="*80)

# Configurações
B = 1000
TAMANHO_AMOSTRA = 21
LIMITE_PVALOR_VARIAVEIS = 0.05
LIMITE_PVALOR_F = 0.01
MINIMO_POR_CATEGORIA = 3  # Micronumerosidade
NIVEL_DE_CONFIANCA = 0.80

alfa = 1 - NIVEL_DE_CONFIANCA

# Obter coeficientes do modelo original
modelo_original = sm.OLS(Y, X).fit()
coeficientes_originais = modelo_original.params
sinais_originais = np.sign(coeficientes_originais)

print(f"Coeficientes do modelo original:")
for var, coef in coeficientes_originais.items():
    print(f"  {var}: {coef:}")

# Contadores
modelos_validos = 0
modelos_invalidos = 0
subamostras_unicas = set()
detalhes_modelos_validos = []
modelos_completos = []  # Nova lista para salvar modelos completos
dados_completos = []    # Nova lista para salvar dados completos

print(f"\nIniciando {B} reamostragens SEM reposição...")

# Combinar X e Y para manter a correspondência
dados_combinados = pd.concat([X, Y], axis=1)

for i in range(B):
    # Reamostragem SEM reposição
    reamostra = dados_combinados.sample(n=TAMANHO_AMOSTRA, replace=False, random_state=i)

    # Verificar subamostras repetidas
    amostra_hash = tuple(sorted(reamostra.index))
    if amostra_hash in subamostras_unicas:
        continue  # Pula subamostras repetidas
    subamostras_unicas.add(amostra_hash)

    # Separar X e Y da reamostra
    X_reamostra = reamostra[X.columns]
    Y_reamostra = reamostra[Y.name]

    try:
        # Critério MICRONUMEROSIDADE - Verificar variáveis dummy
        micronumerosidade_ok = True
        for var_cat in ['nDorm', 'nVagas']:  # Variáveis que foram transformadas em dummies
            if var_cat in dados_combinados.columns:
                contagem_categorias = reamostra[var_cat].value_counts()
                if any(contagem_categorias < MINIMO_POR_CATEGORIA):
                    micronumerosidade_ok = False
                    break

        if not micronumerosidade_ok:
            modelos_invalidos += 1
            continue

        # Ajustar modelo MLR na reamostra
        modelo_reamostra = sm.OLS(Y_reamostra, X_reamostra).fit()

        # Critério a) Compatibilidade de sinais
        sinais_reamostra = np.sign(modelo_reamostra.params)
        compatibilidade_sinais = np.all(sinais_originais == sinais_reamostra)

        # Critério b) TODOS os valores-p das variáveis independentes <= 30% E IC 80% não contém zero
        pvalues_variaveis = modelo_reamostra.pvalues.drop('const', errors='ignore')
        todos_pvalores_validos = all(pval <= LIMITE_PVALOR_VARIAVEIS for pval in pvalues_variaveis)

        # Critério c) Significância do modelo (teste F) <= 5%
        f_significativo = modelo_reamostra.f_pvalue <= LIMITE_PVALOR_F

        # Critério d) IC 80% não contém zero para variáveis significativas
        ic_nivelConfianca = modelo_reamostra.conf_int(alpha=alfa)  # nivel confiança definido no inicio da celula
        ic_sem_zero = True
        for var in pvalues_variaveis.index:
            if pvalues_variaveis[var] <= LIMITE_PVALOR_VARIAVEIS:
                ic_inf, ic_sup = ic_nivelConfianca.loc[var]
                if ic_inf <= 0 <= ic_sup:  # IC contém zero
                    ic_sem_zero = False
                    break

        # Verificar se todos os critérios são atendidos
        modelo_valido = (compatibilidade_sinais and
                        todos_pvalores_validos and
                        f_significativo and
                        ic_sem_zero and
                        micronumerosidade_ok)

        if modelo_valido:
            modelos_validos += 1
            # Salvar modelo completo e dados
            modelos_completos.append(modelo_reamostra)
            dados_completos.append({
                'X': X_reamostra.copy(),
                'Y': Y_reamostra.copy(),
                'reamostra_completa': reamostra.copy()
            })

            detalhes_modelos_validos.append({
                'reamostra': i,
                'compatibilidade_sinais': compatibilidade_sinais,
                'maior_pvalor': pvalues_variaveis.max(),
                'f_pvalue': modelo_reamostra.f_pvalue,
                'r_quadrado': modelo_reamostra.rsquared,
                'micronumerosidade': micronumerosidade_ok,
                'ic_sem_zero': ic_sem_zero,
                'modelo': modelo_reamostra,  # Salva referência ao modelo
                'X_reamostra': X_reamostra,  # Salva dados X
                'Y_reamostra': Y_reamostra   # Salva dados Y
            })
        else:
            modelos_invalidos += 1

        # Progresso a cada 100 reamostragens
        if (i + 1) % 100 == 0:
            print(f"  Concluídas {i + 1} reamostragens... Válidos: {modelos_validos}")

    except Exception as e:
        modelos_invalidos += 1
        continue

# Resultados finais
print("\n" + "="*80)
print("RESULTADOS FINAIS REVISADOS")
print("="*80)
print(f"Total de reamostragens únicas: {len(subamostras_unicas)}")
print(f"Modelos válidos: {modelos_validos}")
print(f"Modelos inválidos: {modelos_invalidos}")
print(f"Taxa de sucesso: {(modelos_validos/len(subamostras_unicas))*100:}%")

print(f"\nCRITÉRIOS DE VALIDAÇÃO REVISADOS:")
print(f"a) Compatibilidade de sinais: TODOS os coeficientes com mesmo sinal")
print(f"b) TODOS p-valores das variáveis independentes ≤ {LIMITE_PVALOR_VARIAVEIS*100}%")
print(f"c) Significância do modelo (F-test) ≤ {LIMITE_PVALOR_F*100}%")
print(f"d) IC 80% não contém zero para variáveis significativas")
print(f"e) Micronumerosidade: ≥ {MINIMO_POR_CATEGORIA} observações por categoria")

if modelos_validos > 0:
    print(f"\nESTATÍSTICAS DOS MODELOS VÁLIDOS:")
    df_validos = pd.DataFrame(detalhes_modelos_validos)
    print(f"R² médio: {df_validos['r_quadrado'].mean():}")
    print(f"Maior p-valor médio: {df_validos['maior_pvalor'].mean():}")
    print(f"p-valor F médio: {df_validos['f_pvalue'].mean():}")

    # Exemplo de como acessar os modelos salvos
    print(f"\nACESSO AOS MODELOS SALVOS:")
    print(f"Total de modelos salvos: {len(modelos_completos)}")
    print(f"Primeiro modelo salvo - R²: {modelos_completos[0].rsquared:}")
    print(f"Para acessar qualquer modelo, use: modelos_completos[i]")
    print(f"Para acessar os dados correspondentes, use: dados_completos[i]")

# Exemplo de como usar os modelos salvos posteriormente
if modelos_validos > 0:
    print(f"\nEXEMPLO DE USO DOS MODELOS SALVOS:")
    print(f"Para exibir o summary do primeiro modelo válido com IC {NIVEL_DE_CONFIANCA}%:")
    print(f"print(modelos_completos[0].summary(alpha={alfa}))")
    print("\nPara acessar os dados do primeiro modelo válido:")
    print("X_primeiro = dados_completos[0]['X']")
    print("Y_primeiro = dados_completos[0]['Y']")

X_primeiro = dados_completos[1]['X']
Y_primeiro = dados_completos[1]['Y']

#X_primeiro.shape
#X_primeiro
X = X_primeiro
Y = Y_primeiro
