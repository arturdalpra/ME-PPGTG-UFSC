import warnings
warnings.filterwarnings("ignore")

print("\n" + "============================================================")
print("MLR: VALIDAÇÃO CRUZADA, K = 10")
print("============================================================")

from sklearn.model_selection import KFold, cross_validate
from sklearn.linear_model import LinearRegression
from sklearn.metrics import (
    make_scorer, mean_squared_error, r2_score,
    mean_absolute_error, mean_absolute_percentage_error
)
import numpy as np

# === Preparação dos dados ===

# Variáveis categóricas e numéricas
vars_categoricas = ['nDorm', 'nVagas']
vars_numericas = ['tipologia', 'renda', 'aPriva', 'idade']

# Criar dummies (sem normalizar)
X = pd.get_dummies(
    trindade_data[vars_categoricas + vars_numericas],
    drop_first=True,
    dtype=int
)

y = trindade_data['vUnitario']

# === Modelo base ===
model = LinearRegression()

# === Validação cruzada K-Fold ===
cv = KFold(n_splits=10, shuffle=True, random_state=12345)

# === Definição dos scorers ===
scoring = {
    'mse' : make_scorer(mean_squared_error, greater_is_better=False),
    'rmse': make_scorer(
        lambda yt, yp: np.sqrt(mean_squared_error(yt, yp)),
        greater_is_better=False
    ),
    'mae' : make_scorer(mean_absolute_error, greater_is_better=False),
    'mape': make_scorer(mean_absolute_percentage_error, greater_is_better=False),
    'r2'  : make_scorer(r2_score)
}



# Executar a validação cruzada
cv_results = cross_validate(
    model,
    X,
    y,
    cv=cv,
    scoring=scoring,
    return_train_score=True
)

# === Cálculo das médias (corrigindo sinais) ===
mse  = -cv_results['test_mse'].mean()
rmse = -cv_results['test_rmse'].mean()
mae  = -cv_results['test_mae'].mean()
mape = -cv_results['test_mape'].mean()
r2   =  cv_results['test_r2'].mean()

# === R² ajustado médio ===
n = X.shape[0]          # total de observações
p = X.shape[1]          # número de preditores

r2_adj = 1 - (1 - r2) * (n - 1) / (n - p - 1)

# =========
# MÉTRICAS
# =========

print("\n" + "=" * 60)
print("MÉTRICAS DE DESEMPENHO - VALIDAÇÃO CRUZADA (K = 10)")
print("=" * 60)
print(f"MSE  (Erro Quadrático Médio)          : {mse:.4f}")
print(f"RMSE (Raiz do Erro Quadrático Médio)   : {rmse:.4f}")
print(f"MAE  (Erro Absoluto Médio)             : {mae:.4f}")
print(f"MAPE (Erro Percentual Absoluto Médio)  : {mape:.4%}")
print(f"R² (Coeficiente de Determinação)       : {r2:.4f}")
print(f"R² Ajustado                             : {r2_adj:.4f}")

print("\nDesvio padrão do MSE (teste):", round(cv_results['test_mse'].std(), 2))

# ============================================================
# LOOCV (Leave-One-Out Cross-Validation) para MLR
# ============================================================

import numpy as np
import pandas as pd
import statsmodels.api as sm
from sklearn.model_selection import LeaveOneOut
from sklearn.metrics import mean_absolute_error, mean_absolute_percentage_error, mean_squared_error

print("\n" + "============================================================")
print("VALIDAÇÃO LEAVE-ONE-OUT (LOOCV) PARA MLR")
print("============================================================")

# --- Variáveis (tipologia NÃO dummy) ---
vars_categoricas = ['nDorm', 'nVagas']     # dummies
vars_numericas   = ['tipologia', 'renda', 'aPriva', 'idade']  # contínuas
response = 'vUnitario'

# --- Construir X e y ---
X_base = pd.get_dummies(
    trindade_data[vars_categoricas + vars_numericas],
    columns=vars_categoricas,
    drop_first=True,
    dtype=int
)

# Adicionar intercepto (constante)
X_base = sm.add_constant(X_base)

# Variável dependente
y_base = trindade_data[response]

# --- LOOCV setup ---
loo = LeaveOneOut()

mae_scores  = []
mape_scores = []
rmse_scores = []
coefs_list  = []

# --- LOOP PRINCIPAL ---
for train_idx, test_idx in loo.split(X_base):
    X_train, X_test = X_base.iloc[train_idx], X_base.iloc[test_idx]
    y_train, y_test = y_base.iloc[train_idx], y_base.iloc[test_idx]

    # Ajustar modelo OLS
    model = sm.OLS(y_train, X_train).fit()

    # Predizer
    y_pred = model.predict(X_test)

    # Métricas
    mae_scores.append(mean_absolute_error(y_test, y_pred))
    mape_scores.append(mean_absolute_percentage_error(y_test, y_pred))
    rmse_scores.append(np.sqrt(mean_squared_error(y_test, y_pred)))

    # Coeficientes do modelo
    coefs_list.append(model.params.values)

# --- RESULTADOS ---
mae_mean  = np.mean(mae_scores)
mape_mean = np.mean(mape_scores)
rmse_mean = np.mean(rmse_scores)

mae_std   = np.std(mae_scores)
mape_std  = np.std(mape_scores)
rmse_std  = np.std(rmse_scores)

print("\nMÉTRICAS MÉDIAS DO LOOCV:")
print(f"MAE  : {mae_mean:.4f} ± {mae_std:.4f}")
print(f"MAPE : {mape_mean:.4f} ± {mape_std:.4f}")
print(f"RMSE : {rmse_mean:.4f} ± {rmse_std:.4f}")

# --- COEFICIENTES MÉDIOS ---
coefs_df = pd.DataFrame(coefs_list, columns=X_base.columns)
coef_means = coefs_df.mean()
coef_stds  = coefs_df.std()

# IC de 80% para cada coeficiente
ci_lower = coefs_df.quantile(0.10)
ci_upper = coefs_df.quantile(0.90)

# Erro padrão do coeficiente baseado no LOOCV
coef_se = coefs_df.std()

coef_summary = pd.DataFrame({
    'Coef_Médio': coefs_df.mean(),
    'Erro_Padrão': coef_se,
    'Desvio_Padrão': coefs_df.std(),
    'IC_80%_Inferior': ci_lower,
    'IC_80%_Superior': ci_upper
}).round(4)

print("\nCOEFICIENTES MÉDIOS COM ERRO PADRÃO E IC DE 80%:")
print(coef_summary)

# --- HISTOGRAMAS PARA CADA COEFICIENTE ---
#for col in coefs_df.columns:
    #plt.figure(figsize=(6,4))
    #plt.hist(coefs_df[col], bins=40, color='skyblue', edgecolor='k', alpha=0.7)
    #plt.title(f'Histograma do Coeficiente: {col}')
    #plt.xlabel('Valor do coeficiente')
    #plt.ylabel('Frequência')
    #plt.axvline(coefs_df[col].mean(), color='red', linestyle='--', label='Média')
    #plt.axvline(ci_lower[col], color='green', linestyle=':', label='IC 10%')
    #plt.axvline(ci_upper[col], color='green', linestyle=':', label='IC 90%')
    #plt.legend()
    #plt.show()

print("\n" + "=" * 60)
print("MÉTRICAS DE DESEMPENHO - LOOCV (LEAVE-ONE-OUT)")
print("=" * 60)
print(f"MAE  (Erro Absoluto Médio)             : {mae_mean:.4f}")
print(f"MAPE (Erro Percentual Absoluto Médio)  : {mape_mean:.4%}")
print(f"RMSE (Raiz do Erro Quadrático Médio)   : {rmse_mean:.4f}")

print("\nDesvios-padrão das métricas (LOOCV):")
print(f"Desvio padrão do MAE                 : {mae_std:.4f}")
print(f"Desvio padrão do MAPE                : {mape_std:.4f}")
print(f"Desvio padrão do RMSE                : {rmse_std:.4f}")

print("\n" + "=" * 60)
print("COEFICIENTES MÉDIOS (LOOCV)")
print("=" * 60)
print(coef_summary)

# --- EXEMPLO DE PREDIÇÃO COM COEFICIENTES MÉDIOS ---
# Montado um novo caso com as mesmas colunas de X_base
novo_caso = pd.DataFrame([{col: 0 for col in X_base.columns}])

# Preencher o intercepto e variáveis desejadas
novo_caso['const'] = 1
novo_caso['tipologia'] = 2
novo_caso['renda'] = 6000
novo_caso['aPriva'] = 80
novo_caso['idade'] = 10
if 'nDorm_3' in novo_caso.columns:
    novo_caso['nDorm_3'] = 1
if 'nVagas_2' in novo_caso.columns:
    novo_caso['nVagas_2'] = 0

# Garantir mesma ordem de colunas
novo_caso = novo_caso[X_base.columns]

# Predição
pred_loocv = float(novo_caso.values.dot(coef_means.values))
print(f"\nPredição usando coeficientes médios (LOOCV): {pred_loocv:.2f}")

"""Bootstrap por pares: é uma técnica de reamostragem que pode ser usada para estimar a variabilidade (incerteza) dos coeficientes de uma regressão.
A ideia de amostrar os pares vem da necessidade de preservar a relação natural entre x e y nos dados originais.

#BOOTSTRAP POR PARES:
(carga da função)
"""

!pip install arch
from arch.bootstrap import IIDBootstrap #para fazer o IC BCa do bootstrap

def estatistica_coef(data, response, vars_categoricas, vars_numericas, colunas_ref, coeficiente):
    Xb = pd.get_dummies(data[vars_categoricas + vars_numericas],
                        columns=vars_categoricas, drop_first=True, dtype=int)
    Xb = sm.add_constant(Xb)
    Xb = Xb.reindex(columns=colunas_ref, fill_value=0)
    yb = data[response]
    modelo_b = sm.OLS(yb, Xb).fit()
    return modelo_b.params[coeficiente]

import numpy as np
import pandas as pd
import statsmodels.api as sm
from arch.bootstrap import IIDBootstrap
import matplotlib.pyplot as plt


# ===============================================================
# Função auxiliar para BCa que retorna um coeficiente específico
# O BCa precisa calcular o viés e a aceleração, então usa-se
# esta função auxiliar
# ===============================================================

def estatistica_coef(data, indices, response, vars_categoricas, vars_numericas, colunas_ref, nome_coef):
    d = data.iloc[indices]

    Xb = pd.get_dummies(
        d[vars_categoricas + vars_numericas],
        columns=vars_categoricas,
        drop_first=True,
        dtype=int
    )
    Xb = sm.add_constant(Xb)
    Xb = Xb.reindex(columns=colunas_ref, fill_value=0)

    yb = d[response]

    modelo = sm.OLS(yb, Xb).fit()
    return modelo.params[nome_coef]

# O código abaixo traz funções com mais de um objetivo.

# Parece ser uma má prática de programação, mas por ser um método intensivo
# em computação, é importante que cada ciclo de bootstrap seja aproveitado ao máximo.

import numpy as np
import pandas as pd
import statsmodels.api as sm
from arch.bootstrap import IIDBootstrap


def bootstrap_pares_MLR_dummies(
    data, response, vars_categoricas, vars_numericas,
    n_bootstrap=1000, random_state=42
):

    np.random.seed(random_state)
    n = len(data)

    # -----------------------------------------------------------
    # Modelo original
    # -----------------------------------------------------------
    X = pd.get_dummies(
        data[vars_categoricas + vars_numericas],
        columns=vars_categoricas,
        drop_first=True,
        dtype=int
    )
    X = sm.add_constant(X)
    colunas_ref = X.columns

    Y = data[response]
    modelo_original = sm.OLS(Y, X).fit()
    coefs_originais = modelo_original.params
    se_original = modelo_original.bse

    # -----------------------------------------------------------
    # Bootstrap por pares
    # -----------------------------------------------------------
    coeficientes = []
    se_boot = []

    for b in range(n_bootstrap):
        idx = np.random.choice(np.arange(n), size=n, replace=True)
        dboot = data.iloc[idx]

        Xb = pd.get_dummies(
            dboot[vars_categoricas + vars_numericas],
            columns=vars_categoricas,
            drop_first=True,
            dtype=int
        )
        Xb = sm.add_constant(Xb)
        Xb = Xb.reindex(columns=colunas_ref, fill_value=0)

        yb = dboot[response]

        modb = sm.OLS(yb, Xb).fit()

        coeficientes.append(modb.params)
        se_boot.append(modb.bse)

    resultados_boot = pd.DataFrame(coeficientes)
    se_boot = pd.DataFrame(se_boot)

    # ===========================================================
    # IC Percentil (80%)
    # ===========================================================
    IC_percentil = pd.DataFrame({
        col: np.percentile(resultados_boot[col], [10, 90])
        for col in resultados_boot.columns
    }, index=['10%', '90%']).T

    # ===========================================================
    # IC Normalizado (Normal-based, 80%)
    # ===========================================================
    z_80 = 1.2816  # quantil 90% da normal padrão (para IC 80%)
    IC_normalizado = pd.DataFrame({
        col: [
            coefs_originais[col] - z_80 * se_original[col],
            coefs_originais[col] + z_80 * se_original[col]
        ]
        for col in resultados_boot.columns
    }, index=['10%', '90%']).T

    # ===========================================================
    # IC BCa (80%)
    # ===========================================================
    IC_bca = {}
    boot_obj = IIDBootstrap(np.arange(len(data)))

    for col in resultados_boot.columns:
        func_idx = lambda idx: estatistica_coef(
            data, idx.astype(int), response, vars_categoricas,
            vars_numericas, colunas_ref, col
        )

        ci_low, ci_high = boot_obj.conf_int(
            func_idx, reps=n_bootstrap,
            method='bca', size=0.80
        )
        IC_bca[col] = [ci_low, ci_high]

    IC_bca = pd.DataFrame(IC_bca, index=['10%', '90%']).T


    # Para cada linha# Remove os colchetes [] usando regex e converte para float
    IC_bca = IC_bca.applymap(lambda x: float(str(x).replace('[', '').replace(']', '')))
    IC_bca




    # ===========================================================
    # P-VALORES BOOTSTRAP
    # ===========================================================
    p_values = {}
    for col in resultados_boot.columns:
        theta = coefs_originais[col]
        boots = resultados_boot[col]

        if theta >= 0:
            p = 2 * np.mean(boots <= 0)
        else:
            p = 2 * np.mean(boots >= 0)

        p_values[col] = min(p, 1.0)

    p_values = pd.Series(p_values, name="p_bootstrap")

    # ===========================================================
    # Resumo
    # ===========================================================
    resumo = resultados_boot.describe(percentiles=[0.10, 0.90]).T
    resumo = resumo[['mean', 'std', '10%', '90%']]
    resumo.columns = ['Media', 'Desvio_Padrao', 'IC_10', 'IC_90']

    return (
        resumo.round(4),
        resultados_boot,
        IC_percentil.round(4),
        IC_normalizado.round(4),
        IC_bca.round(4),
        p_values.round(4),
        coefs_originais.round(4)
    )

import matplotlib.pyplot as plt
import math

def plot_bootstrap(resultados_boot, coefs_originais):
    p = resultados_boot.shape[1]
    nrows = math.ceil(p / 3)

    fig, axes = plt.subplots(nrows=nrows, ncols=3, figsize=(15, 4*nrows))
    axes = axes.flatten()

    for i, col in enumerate(resultados_boot.columns):
        ax = axes[i]
        resultados_boot[col].plot(kind='kde', ax=ax)
        ax.axvline(coefs_originais[col], color='red', linestyle='--', lw=2)
        ax.set_title(f"{col}")

    for j in range(i+1, len(axes)):
        fig.delaxes(axes[j])

    plt.tight_layout()
    plt.show()

